generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Difficulty {
  easy
  medium
  hard

  @@map("difficulty")
}

enum MealType {
  breakfast
  lunch
  dinner

  @@map("meal_type")
}

enum ChefPersonality {
  home
  french
  street

  @@map("chef_personality")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  password      String?
  name          String?
  image         String?
  isAdmin       Boolean   @default(false) @map("is_admin")

  unsubscribeToken    String?   @unique @map("unsubscribe_token")
  emailUnsubscribedAt DateTime? @map("email_unsubscribed_at")
  notifyMarketing     Boolean   @default(true) @map("notify_marketing")
  notifyProduct       Boolean   @default(true) @map("notify_product")

  pendingEmail      String?   @map("pending_email")
  emailChangeToken  String?   @unique @map("email_change_token")
  emailChangeExpiry DateTime? @map("email_change_expiry")

  sessionsRevokedAt DateTime? @map("sessions_revoked_at")

  // F30: Freemium gate
  isPro            Boolean   @default(false) @map("is_pro")
  recipeCount      Int       @default(0) @map("recipe_count")
  monthlyResetDate DateTime? @map("monthly_reset_date")

  // F53: Budget mode preference
  budgetMode Boolean @default(false) @map("budget_mode")

  // F70: Chef personality preference
  chefPersonality ChefPersonality @default(home) @map("chef_personality")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  accounts          Account[]
  sessions          Session[]
  recipes           Recipe[]
  mealPlans         MealPlan[]
  collections       RecipeCollection[]
  dietaryProfile    DietaryProfile?
  pantryItems       PantryItem[]
  recipeCompletions RecipeCompletion[]

  @@index([email])
  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@map("password_reset_tokens")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  action    String
  ip        String?
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Recipe {
  id          String      @id @default(cuid())
  userId      String      @map("user_id")
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?     @db.Text
  servings    Int         @default(4)
  prepTimeMin Int?        @map("prep_time_min")
  cookTimeMin Int?        @map("cook_time_min")
  cuisine     String?
  difficulty  Difficulty?

  sourceIngredients String[] @map("source_ingredients")
  recipeData        Json     @map("recipe_data")
  rawText           String   @map("raw_text") @db.Text
  nutrition         Json?
  fromPhoto         Boolean  @default(false) @map("from_photo")
  modifications     Json     @default("[]")

  // F38: tagging
  tags String[] @default([])

  // F39: collections
  collectionId String?           @map("collection_id")
  collection   RecipeCollection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)

  // F41: completion tracking
  cookedCount  Int       @default(0) @map("cooked_count")
  lastCookedAt DateTime? @map("last_cooked_at")

  // F51: personal star rating (1–5), nullable = unrated
  rating Int? @map("rating")

  // F47: recipe completions (separate model for streak tracking)
  completions RecipeCompletion[]

  // F27: public sharing via permalink
  isPublic   Boolean @default(false) @map("is_public")
  publicSlug String? @unique @map("public_slug")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  mealPlanSlots MealPlanSlot[]

  @@index([userId])
  @@index([collectionId])
  @@map("recipes")
}

// F47: per-day cooking log for streak and heatmap (separate from cookedCount on Recipe)
model RecipeCompletion {
  id       String   @id @default(cuid())
  userId   String   @map("user_id")
  recipeId String   @map("recipe_id")
  cookedAt DateTime @default(now()) @map("cooked_at")
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe   Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([userId, cookedAt(sort: Desc)])
  @@index([recipeId])
  @@map("recipe_completions")
}

// F39: Recipe collections/folders
model RecipeCollection {
  id          String  @id @default(cuid())
  userId      String  @map("user_id")
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String? @db.Text
  color       String  @default("#22c55e") // default green

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  recipes Recipe[]

  @@index([userId])
  @@map("recipe_collections")
}

model MealPlan {
  id        String         @id @default(cuid())
  userId    String         @map("user_id")
  weekStart DateTime       @map("week_start")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  slots     MealPlanSlot[]

  @@unique([userId, weekStart])
  @@index([userId])
  @@map("meal_plans")
}

model MealPlanSlot {
  id         String   @id @default(cuid())
  mealPlanId String   @map("meal_plan_id")
  dayOfWeek  Int      @map("day_of_week")
  mealType   MealType @map("meal_type")
  recipeId   String   @map("recipe_id")
  mealPlan   MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  recipe     Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([mealPlanId, dayOfWeek, mealType])
  @@index([mealPlanId])
  @@index([recipeId])
  @@map("meal_plan_slots")
}

model JobRun {
  id         String    @id @default(cuid())
  job        String
  trigger    String    @default("cron")
  startedAt  DateTime  @default(now()) @map("started_at")
  finishedAt DateTime? @map("finished_at")
  durationMs Int?      @map("duration_ms")
  success    Boolean?
  result     Json?
  error      String?   @db.Text

  @@index([job, startedAt(sort: Desc)])
  @@map("job_runs")
}

model AdminScriptLog {
  id           String   @id @default(cuid())
  scriptName   String   @map("script_name")
  ranAt        DateTime @default(now()) @map("ran_at")
  ranByUserId  String?  @map("ran_by_user_id")
  rowsAffected Json?    @map("rows_affected")
  status       String
  errorMessage String?  @map("error_message")

  @@index([scriptName, ranAt(sort: Desc)])
  @@map("admin_script_logs")
}

// F31: Dietary profile — persisted per user, injected into every AI generation
model DietaryProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique @map("user_id")
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // JSON arrays stored as String[] for Postgres native array support
  restrictions        String[] @default([]) // e.g. ["vegan", "gluten-free", "nut-allergy"]
  cuisinePrefs        String[] @default([]) @map("cuisine_prefs") // e.g. ["Italian", "Asian"]
  dislikedIngredients String[] @default([]) @map("disliked_ingredients")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("dietary_profiles")
}

// F44: Pantry inventory — persistent ingredient list tracked between sessions
// F26: expiresAt added for expiry-first mode
model PantryItem {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ingredient String
  addedAt    DateTime  @default(now()) @map("added_at")
  expiresAt  DateTime? @map("expires_at") // nullable — not all items have an expiry date

  @@unique([userId, ingredient]) // prevent duplicate entries per user
  @@index([userId])
  @@map("pantry_items")
}
